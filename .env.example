# === Shopify App Credentials ===
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_products,write_products,read_orders,write_orders,read_customers,read_returns,write_returns

# === App Settings ===
APP_NAME=ReturnShield AI
APP_URL=https://your-app-url.com
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# === Database ===
DATABASE_URL=postgresql+asyncpg://returnshield:returnshield@localhost:5432/returnshield
DATABASE_URL_SYNC=postgresql://returnshield:returnshield@localhost:5432/returnshield

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Celery ===
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# === Sentry (optional) ===
SENTRY_DSN=

# === ML Settings ===
ML_MODEL_DIR=./ml_models
ML_RETRAIN_INTERVAL_HOURS=168
